

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>iCREAM - Complete FAQ | 100+ Questions Answered</title>
    <!-- Google Fonts + Font Awesome + Bootstrap -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:ital,wght@@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>

    <div class="faq-page">
        <!-- Hero Section -->
        <div class="faq-hero">
            <div class="brand-icon">
                <i class="fas fa-ice-cream"></i>
            </div>
            <h1>Frequently Asked Questions</h1>
            <p>Everything you need to know about iCREAM Parlor — from membership and recipes to contests and orders</p>
    
            <div class="faq-stats">
                <span class="stat-item"><i class="fas fa-question-circle"></i> 100+ Questions</span>
                <span class="stat-item"><i class="fas fa-tag"></i> 12 Categories</span>
                <span class="stat-item"><i class="fas fa-users"></i> 20+ Flavors</span>
                <span class="stat-item"><i class="fas fa-trophy"></i> Recipe Contest</span>
            </div>
        </div>

        <!-- Search Bar -->
        <div class="faq-search">
            <input type="text" id="faqSearchInput" placeholder="Search your question..." onkeyup="searchFAQ()">
        </div>

        <!-- Category Filters -->
        <div class="faq-categories" id="categoryFilters">
            <!-- Categories will be injected via JS -->
        </div>

        <!-- FAQ Accordion -->
        <div class="faq-accordion" id="faqContainer">
            <!-- FAQ items will be injected via JavaScript -->
        </div>

        <!-- Still Have Questions -->
        <div class="still-questions">
            <h3>Still have questions?</h3>
            <p>We're here to help! Reach out to us anytime.</p>
            <div class="contact-btns">
                <a href="contact.html" class="btn-contact"><i class="fas fa-envelope"></i> Contact Us</a>
                <a href="feedback.html" class="btn-feedback"><i class="fas fa-comment"></i> Give Feedback</a>
            </div>
        </div>
    </div>

    <script src="~/js/min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>