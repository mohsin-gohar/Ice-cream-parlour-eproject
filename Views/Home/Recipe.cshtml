<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🍦 Vanilla · recipe cards</title>
  <!-- Font Awesome for icons (optional but nice) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="~/css/style.css" rel="stylesheet">
    <link href="~/css/style.min.css" rel="stylesheet">

</head>
<body>
  <!-- notice bar (exactly as given) -->
  <div class="sample-notice-bar">
    <p>✨ <strong>Free Sample Recipe:</strong> You are viewing a limited-access community recipe. <a href="#">Register now</a> to unlock 100+ premium flavors!</p>
  </div>

  <section class="recipe-detail-section">
    <div class="recipe-container">

      <!-- ----- CARDS GRID (all recipes) ----- -->
      <div id="cardsGrid" class="cards-grid">
        <!-- card 1: Madagascar Vanilla -->
        <div class="recipe-card" data-recipe="vanilla">
          <img class="card-img" src="https://images.unsplash.com/photo-1570145820259-b5b80c5c8bd6?q=80&w=600&auto=format&fit=crop" alt="Madagascar Vanilla">
          <div class="card-content">
            <span class="card-badge">Free Access</span>
            <div class="card-title">Madagascar Vanilla</div>
            <div class="card-meta">
              <span><i class="fas fa-clock"></i> 25 min</span>
              <span><i class="fas fa-ice-cream"></i> 1 qt</span>
            </div>
            <div class="card-desc">Floral, creamy, organic vanilla bean. Classic beginner recipe.</div>
            <button class="btn-detail" data-recipe="vanilla"><i class="fas fa-arrow-right"></i> View Details</button>
          </div>
        </div>

        <!-- card 2: Chocolate Fudge -->
        <div class="recipe-card" data-recipe="chocolate">
          <img class="card-img" src="https://images.unsplash.com/photo-1563805042-7684c019e1cb?q=80&w=600&auto=format&fit=crop" alt="Chocolate Fudge">
          <div class="card-content">
            <span class="card-badge">Premium</span>
            <div class="card-title">Chocolate Fudge</div>
            <div class="card-meta">
              <span><i class="fas fa-clock"></i> 35 min</span>
              <span><i class="fas fa-ice-cream"></i> 1.5 qt</span>
            </div>
            <div class="card-desc">Deep dark cocoa, fudge swirls, extra creamy.</div>
            <button class="btn-detail" data-recipe="chocolate"><i class="fas fa-arrow-right"></i> View Details</button>
          </div>
        </div>

        <!-- card 3: Strawberry Bliss -->
        <div class="recipe-card" data-recipe="strawberry">
          <img class="card-img" src="https://images.unsplash.com/photo-1551024506-0bccd828d307?q=80&w=600&auto=format&fit=crop" alt="Strawberry Bliss">
          <div class="card-content">
            <span class="card-badge">Free Access</span>
            <div class="card-title">Strawberry Bliss</div>
            <div class="card-meta">
              <span><i class="fas fa-clock"></i> 30 min</span>
              <span><i class="fas fa-ice-cream"></i> 1 qt</span>
            </div>
            <div class="card-desc">Fresh strawberries, tangy-sweet, perfect for summer.</div>
            <button class="btn-detail" data-recipe="strawberry"><i class="fas fa-arrow-right"></i> View Details</button>
          </div>
        </div>

        <!-- card 4: Salted Caramel -->
        <div class="recipe-card" data-recipe="caramel">
          <img class="card-img" src="https://images.unsplash.com/photo-1580915411954-282cb1b0d780?q=80&w=600&auto=format&fit=crop" alt="Salted Caramel">
          <div class="card-content">
            <span class="card-badge">Premium</span>
            <div class="card-title">Salted Caramel</div>
            <div class="card-meta">
              <span><i class="fas fa-clock"></i> 40 min</span>
              <span><i class="fas fa-ice-cream"></i> 1 qt</span>
            </div>
            <div class="card-desc">Buttery caramel, sea salt, dulce de leche swirl.</div>
            <button class="btn-detail" data-recipe="caramel"><i class="fas fa-arrow-right"></i> View Details</button>
          </div>
        </div>
      </div>

      <!-- ----- DETAIL VIEW (hidden by default) ----- -->
      <div id="detailView" class="detail-view">
        <button class="detail-back" id="backToCards"><i class="fas fa-chevron-left"></i> Back to recipes</button>
        
        <!-- detail content injected from JS -->
        <div id="detailContent">
          <!-- will be filled dynamically -->
        </div>
      </div>
<script src="~/js/site.js"></script>
    </div>
  </section>

  

</body>
</html>