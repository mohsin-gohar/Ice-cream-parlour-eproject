@model IEnumerable<Ice_Cream_Parlour_Eproject.Models.Book>

@{
    ViewData["Title"] = "Recipe Books - iCREAM";
}

<!-- Page Header -->
<div class="bg-primary py-5">
    <div class="container text-center py-4">
        <h1 class="text-white display-3">Recipe Books</h1>
        <div class="d-inline-flex align-items-center text-white">
            <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none">Home</a>
            <i class="fa fa-circle px-3" style="font-size: 6px;"></i>
            <span>Books</span>
        </div>
    </div>
</div>

<!-- Books Grid -->
<section class="container py-5">
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="@item.ImagePath" class="card-img-top" style="height: 250px; object-fit: cover;" alt="@item.Title">
                    }
                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">@item.Title</h5>
                        <p class="text-muted">by @item.Author</p>
                        <p class="card-text small">@item.Description</p>
                        <h4 class="text-primary fw-bold">$@item.Price</h4>
                        <a asp-controller="Book" asp-action="Order" asp-route-id="@item.Id" class="btn btn-success w-100 mt-2">
                            <i class="fas fa-shopping-cart"></i> Order Now
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>