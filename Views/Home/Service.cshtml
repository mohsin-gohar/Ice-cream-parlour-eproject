<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>iCREAM - Service</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">
    <link href="~/css/style.min.css" rel="stylesheet">
</head>
<body>

    <!-- Page Header Start - Clean Version (No Breadcrumb) -->
    <div class="page-header">
        <div class="container text-center">
            <div class="header-content">
                <h1>Our Services</h1>
                <p>Premium ice cream services for every occasion</p>
            </div>
        </div>
    </div>
    <!-- Page Header End -->
    <!-- Counter Section -->
    <section class="counter-section">
        <div class="container">
            <div class="counter-grid">
                <div class="counter-item">
                    <div class="counter-number" data-target="15000">5000+</div>
                    <div class="counter-label">Happy Customers</div>
                </div>
                <div class="counter-item">
                    <div class="counter-number" data-target="20">200+</div>
                    <div class="counter-label">Premium Flavors</div>
                </div>
                <div class="counter-item">
                    <div class="counter-number" data-target="5000">3000+</div>
                    <div class="counter-label">Orders Delivered</div>
                </div>
                <div class="counter-item">
                    <div class="counter-number" data-target="8">1500</div>
                    <div class="counter-label">Years of Excellence</div>
                </div>
            </div>
        </div>
    </section>
    <!-- Counter End -->
    <!-- Services Section Start -->
    <div class="services-section">
        <div class="container">
            <div class="section-title">
                <h2>Best Services We Provide</h2>
                <h3>For Our Clients</h3>
            </div>

            <div class="services-cards">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-medal"></i>
                    </div>
                    <h3>Quality Maintain</h3>
                    <p>We use only the finest ingredients to craft every scoop with care, ensuring premium taste in every bite you enjoy.</p>
                    <a href="#" class="service-link">Learn More →</a>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-user-check"></i>
                    </div>
                    <h3>Individual Approach</h3>
                    <p>Every customer is unique. We tailor our service to match your taste preferences and create your perfect experience.</p>
                    <a href="#" class="service-link">Learn More →</a>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-birthday-cake"></i>
                    </div>
                    <h3>Celebration Ice Cream</h3>
                    <p>Make your special moments sweeter with our custom celebration cakes and festive ice cream creations.</p>
                    <a href="#" class="service-link">Learn More →</a>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-truck-fast"></i>
                    </div>
                    <h3>Delivery To Any Point</h3>
                    <p>Fresh and cold, delivered right to your door. We ensure your order arrives on time wherever you are.</p>
                    <a href="#" class="service-link">Learn More →</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Services Section End -->
    <!-- Testimonial Start -->
    <div class="testimonial-section" style="margin-bottom:auto;>
        <div class="container">
            <div class="section-title">
                <h2>Clients Say About Our</h2>
                <h3>Famous Ice Cream</h3>
            </div>

            <div class="testimonial-wrapper">
                <button class="carousel-btn prev-btn" id="prevBtn">
                    <i class="fas fa-chevron-left"></i>
                </button>

                <div class="testimonial-carousel">
                    <div class="testimonial-slide active">
                        <i class="fa fa-quote-left quote-icon"></i>
                        <p class="testimonial-text">The ice cream here is absolutely divine! Every flavor is crafted to perfection and the delivery was super fast. Will definitely order again!</p>
                        <div class="testimonial-avatar">
                            <div class="avatar-circle">S</div>
                        </div>
                        <h5 class="client-name">Sarah Johnson</h5>
                        <span class="client-role">Food Blogger</span>
                    </div>

                    <div class="testimonial-slide">
                        <i class="fa fa-quote-left quote-icon"></i>
                        <p class="testimonial-text">Ordered the celebration cake for my daughter's birthday and it was a huge hit! Beautiful presentation and the taste was out of this world.</p>
                        <div class="testimonial-avatar">
                            <div class="avatar-circle">M</div>
                        </div>
                        <h5 class="client-name">Michael Torres</h5>
                        <span class="client-role">Happy Parent</span>
                    </div>

                    <div class="testimonial-slide">
                        <i class="fa fa-quote-left quote-icon"></i>
                        <p class="testimonial-text">Been a loyal customer for 3 years. The quality never drops and the flavors keep getting better. iCREAM is simply the best in town!</p>
                        <div class="testimonial-avatar">
                            <div class="avatar-circle">A</div>
                        </div>
                        <h5 class="client-name">Aisha Malik</h5>
                        <span class="client-role">Regular Customer</span>
                    </div>
                </div>

                <button class="carousel-btn next-btn" id="nextBtn">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>

            <div class="carousel-dots">
                <span class="dot active" data-index="0"></span>
                <span class="dot" data-index="1"></span>
                <span class="dot" data-index="2"></span>
            </div>
        </div>
    </div>
    <!-- Testimonial End -->
    <!-- Back to Top -->
    <a href="#" class="back-to-top" id="backToTop">
        <i class="fas fa-angle-double-up"></i>
    </a>

    <script src="~/js/main.js"></script>
</body>
</html>