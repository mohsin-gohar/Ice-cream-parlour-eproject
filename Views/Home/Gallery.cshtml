<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>iCREAM — Artisan Gallery</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="~/css/style.css" rel="stylesheet">
    <link href="~/css/style.min.css" rel="stylesheet">

</head>
<body>


    <!-- HERO -->
    <div class="page-header">
        <div class="container text-center">
            <div class="header-content">
                <h1>Our Gallery</h1>
                <p>A visual treat of our premium ice cream flavors and events</p>
            </div>
        </div>
    </div>

    <div class="filter-bar">
        <button class="filter-chip active">All Flavors</button>
        <button class="filter-chip">Classic</button>
        <button class="filter-chip">Fruit</button>
        <button class="filter-chip">Nut & Cream</button>
        <button class="filter-chip">Seasonal</button>
        <button class="filter-chip">Sugar-Free</button>
        <button class="filter-chip">Vegan</button>
    </div>

    <section class="gallery-section">
        <p class="section-label">Our Collection</p>
        <h2 class="section-heading">Signature Flavors</h2>

        <div class="gallery-grid">

            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery1.jpg" alt="Madagascar Vanilla" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Madagascar Vanilla</div>
                    <div class="price-tag">$3.99 <span>/ scoop</span></div>
                </div>
            </div>

            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery2.jpg" alt="Belgian Dark Chocolate" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Belgian Dark Chocolate</div>
                    <div class="price-tag">$4.50 <span>/ scoop</span></div>
                </div>
            </div>

            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRbLvmAeifOnse5RIa5U0q-rQXwE31C9zVdmjdHpoo4tg&s" alt="Fresh Strawberry" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Fresh Strawberry</div>
                    <div class="price-tag">$3.75 <span>/ scoop</span></div>
                </div>
            </div>

            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery4.jpg" alt="Alphonso Mango" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Alphonso Mango</div>
                    <div class="price-tag">$4.25 <span>/ scoop</span></div>
                </div>
            </div>

            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery5.jpg" alt="Bronte Pistachio" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Bronte Pistachio</div>
                    <div class="price-tag">$5.50 <span>/ scoop</span></div>
                </div>
            </div>

            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery6.jpg" alt="Butterscotch Caramel" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Butterscotch Caramel</div>
                    <div class="price-tag">$3.99 <span>/ scoop</span></div>
                </div>
            </div>

            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery7.jpg" alt="Persian Rose" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Persian Rose</div>
                    <div class="price-tag">$4.75 <span>/ scoop</span></div>
                </div>
            </div>

            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/product-8.jpg" alt="Wild Blueberry" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Wild Blueberry</div>
                    <div class="price-tag">$4.25 <span>/ scoop</span></div>
                </div>
            </div>

            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery9.jpg" alt="Espresso Crunch" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Espresso Crunch</div>
                    <div class="price-tag">$4.99 <span>/ scoop</span></div>
                </div>
            </div>
            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery9.jpg" alt="Espresso Crunch" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Espresso Crunch</div>
                    <div class="price-tag">$4.99 <span>/ scoop</span></div>
                </div>
            </div>
            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery9.jpg" alt="Espresso Crunch" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Espresso Crunch</div>
                    <div class="price-tag">$4.99 <span>/ scoop</span></div>
                </div>
            </div>
            <div class="flavor-card">
                <div class="card-image-box">
                    <img src="~/img/gallery9.jpg" alt="Espresso Crunch" class="flavor-img">
                </div>
                <div class="card-body">
                    <div class="flavor-name">Espresso Crunch</div>
                    <div class="price-tag">$4.99 <span>/ scoop</span></div>
                </div>
            </div>

        </div>
    </section>




    <script>
            document.querySelectorAll('.filter-chip').forEach(chip => {
              chip.addEventListener('click', function() {
                document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
              });
            });
    </script>
    <script src="~/js/main.js"></script>
</body>
</html>
