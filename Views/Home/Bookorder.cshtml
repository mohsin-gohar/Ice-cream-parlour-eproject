<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>iCREAM - Recipe Books Order</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>

    <div class="books-page">
        <div class="page-header">
            <h1><i class="fas fa-book-open"></i> Recipe Books</h1>
            <p>Discover Mr. A's collection of handcrafted recipe books — from classic ice cream to gourmet desserts</p>
            <div class="badge-group">
                <span><i class="fas fa-ice-cream"></i> 5 Books</span>
                <span><i class="fas fa-trophy"></i> Bestseller</span>
                <span><i class="fas fa-gift"></i> Free Shipping over $100</span>
                <span><i class="fas fa-user"></i> 10% Off for Members</span>
            </div>
        </div>

        <div class="books-grid" id="booksGrid"></div>

        <div class="membership-banner">
            <div class="text">
                <h3><i class="fas fa-crown" style="color: var(--primary);"></i> Registered Members Get 10% Off!</h3>
                <p><i class="fas fa-check-circle"></i> Sign up for Monthly ($15) or Yearly ($150) membership and enjoy exclusive discounts on all books</p>
            </div>
            <a href="#" class="btn-membership"><i class="fas fa-user-plus"></i> Register Now</a>
        </div>
    </div>

    <div class="order-modal-overlay" id="orderModal">
        <div class="order-modal">
            <button class="modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>

            <div class="modal-header">
                <h2>Order <span id="modalBookTitle">Recipe Book</span></h2>
                <p>Fill in your details to complete the purchase</p>
            </div>

            <form class="order-form" id="orderForm" onsubmit="submitOrder(event)">
                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Full Name <span class="required">*</span></label>
                        <input type="text" id="fullName" placeholder="John Doe" required>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-envelope"></i> Email <span class="required">*</span></label>
                        <input type="email" id="email" placeholder="john@example.com" required>
                    </div>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-phone"></i> Contact Number <span class="required">*</span></label>
                    <input type="tel" id="phone" placeholder="+1 234 567 8900" required>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-map-marker-alt"></i> Delivery Address <span class="required">*</span></label>
                    <textarea id="address" placeholder="Street, City, State, ZIP Code" required></textarea>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-credit-card"></i> Payment Method <span class="required">*</span></label>
                    <select id="paymentMethod" required>
                        <option value="">Select Payment Method</option>
                        <option value="credit">Credit Card</option>
                        <option value="debit">Debit Card</option>
                    </select>
                </div>

                <div id="cardDetails" style="display:none;">
                    <div class="form-row">
                        <div class="form-group">
                            <label><i class="fas fa-id-card"></i> Card Number</label>
                            <input type="text" id="cardNumber" placeholder="1234 5678 9012 3456">
                        </div>
                        <div class="form-group">
                            <label><i class="fas fa-calendar-alt"></i> Expiry</label>
                            <input type="text" id="expiry" placeholder="MM/YY">
                        </div>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> CVV</label>
                        <input type="text" id="cvv" placeholder="123">
                    </div>
                </div>

                <div class="order-summary">
                    <span class="label"><i class="fas fa-shopping-cart"></i> Total Amount</span>
                    <span class="amount" id="orderTotal">$0.00</span>
                </div>

                <button type="submit" class="btn-submit-order">
                    <i class="fas fa-check-circle"></i> Complete Order
                </button>
            </form>
        </div>
    </div>

    <div class="toast-message" id="toast">
        <i class="fas fa-check-circle"></i>
        <span id="toastText">Order placed successfully!</span>
    </div>

    <script src="~/js/main.js"></script>
</body>
</html>