@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied - iCREAM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <div class="auth-card access-denied">
        <i class="fas fa-ban"></i>
        <h2>Access Denied</h2>
        <p class="mb-4">You don't have permission to access this page.</p>
        <a asp-controller="Home" asp-action="Index" class="btn-auth d-inline-block" style="width:auto;padding:0.75rem 2rem">Go Home</a>
        <div class="auth-links mt-3"><a asp-action="Login">Sign in with different account</a></div>
    </div>
</body>
</html>
