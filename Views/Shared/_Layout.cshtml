<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - iCREAM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- Navbar Start -->
        <div class="container-fluid position-relative nav-bar p-0" style="width:100%;">
            <div class="container-lg position-relative p-0 px-lg-3" style="z-index: 9;">
                <nav class="navbar navbar-expand-lg bg-white navbar-light shadow p-lg-0">
                    <a asp-action="Index" asp-controller="Home" class="navbar-brand d-block d-lg-none">
                        <h1 class="m-0 display-4 text-primary"><span class="text-secondary">i</span>CREAM</h1>
                    </a>
                    <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                        <div class="navbar-nav ml-auto py-0">
                            <a asp-action="Index" asp-controller="Home" class="nav-item nav-link active">Home</a>
                            <a asp-action="About" asp-controller="Home" class="nav-item nav-link">About</a>
                            <a asp-action="Product" asp-controller="Home" class="nav-item nav-link">Product</a>
                            <a asp-action="Privacy" asp-controller="Home" class="nav-item nav-link">Privacy</a>
                        </div>
                        <a asp-action="Index" asp-controller="Home" class="navbar-brand mx-5 d-none d-lg-block">
                            <h1 class="m-0 display-4 text-primary"><span class="text-secondary">i</span>CREAM</h1>
                        </a>
                        <div class="navbar-nav mr-auto py-0">
                            <a asp-action="Service" asp-controller="Home" class="nav-item nav-link">Service</a>
                            <a asp-action="Gallery" asp-controller="Home" class="nav-item nav-link">Gallery</a>
                            <a asp-action="Contact" asp-controller="Home" class="nav-item nav-link">Contact</a>
                            <a asp-action="Recipe" asp-controller="Home" class="nav-item nav-link">Recipe</a>
                            <a asp-controller="Account" asp-action="Login" class="nav-item nav-link"><i class="fas fa-user-lock"></i> Admin</a>
                        </div>
                    </div>
                </nav>
            </div>
        </div>
        <!-- Navbar End -->
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer Start -->
    <!-- ============================================
   MEMBERSHIP BANNER + FOOTER
============================================ -->
    <!-- Membership Banner -->
    <div class="membership-banner">
        <div class="container">
            <div class="mb-wrapper">
                <div class="mb-left">
                    <div class="mb-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <rect x="3" y="11" width="18" height="11" rx="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            <circle cx="12" cy="16" r="1" />
                        </svg>
                    </div>
                    <div class="mb-text">
                        <h3>Full recipes available for members only</h3>
                        <p>Join to unlock all 20+ artisan recipes, technique guides &amp; monthly exclusives.</p>
                    </div>
                </div>
                <div class="mb-right">
                    <div class="mb-plans">
                        <div class="plan-pill">
                            <div class="plan-price">$15</div>
                            <div class="plan-label">Monthly</div>
                        </div>
                        <div class="plan-pill highlight">
                            <div class="plan-price">$150</div>
                            <div class="plan-label">Yearly · Save 17%</div>
                        </div>
                    </div>
                    <a asp-controller="Account" asp-action="Login" class="btn-membership">
                        <i class="fas fa-user-plus"></i> Login / Register
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================================
   FOOTER START
============================================ -->
    <footer class="footer" style="margin-top:10px;">
        <div class="container">
            <div class="footer-grid">

                <!-- Column 1 - Brand -->
                <div class="footer-col">
                    <div class="footer-logo">
                        <h2><span class="text-primary">i</span><span class="text-secondary">CREAM</span></h2>
                    </div>
                    <p class="footer-desc">
                        Traditional &amp; Delicious Ice Cream Since 1950.
                        Made with love and the finest ingredients.
                    </p>
                    <div class="footer-social">
                        <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                        <a href="#" aria-label="Pinterest"><i class="fab fa-pinterest-p"></i></a>
                    </div>
                </div>

                <!-- Column 2 - Quick Links -->
                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <ul class="footer-links">
                        <li><a asp-action="index" asp-controller="Home"><i class="fas fa-chevron-right"></i> Home</a></li>
                        <li><a asp-action="about" asp-controller="Home"><i class="fas fa-chevron-right"></i> About Us</a></li>
                        <li><a asp-action="Service" asp-controller="Home"><i class="fas fa-chevron-right"></i> Services</a></li>
                        <li><a asp-action="Gallery" asp-controller="Home"><i class="fas fa-chevron-right"></i> Gallery</a></li>
                        <li><a asp-action="contact" asp-controller="Home"><i class="fas fa-chevron-right"></i> Contact</a></li>
                        <li><a asp-action="Feedback" asp-controller="Home"><i class="fas fa-chevron-right"></i> Feedback</a></li>
                    </ul>
                </div>

                <!-- Column 3 - Recipes -->
                <div class="footer-col">
                    <h4>Popular Flavors</h4>
                    <ul class="footer-links">
                        <li><a href="recipes.html"><i class="fas fa-chevron-right"></i> Vanilla Bliss</a></li>
                        <li><a href="recipes.html"><i class="fas fa-chevron-right"></i> Chocolate Delight</a></li>
                        <li><a href="recipes.html"><i class="fas fa-chevron-right"></i> Strawberry Swirl</a></li>
                        <li><a href="recipes.html"><i class="fas fa-chevron-right"></i> Mango Tango</a></li>
                        <li><a href="recipes.html"><i class="fas fa-chevron-right"></i> Pistachio Dream</a></li>
                        <li><a href="recipes.html"><i class="fas fa-chevron-right"></i> All Flavors →</a></li>
                    </ul>
                </div>

                <!-- Column 4 - Contact Info -->
                <div class="footer-col">
                    <h4>Get In Touch</h4>
                    <ul class="footer-contact">
                        <li>
                            <i class="fas fa-map-marker-alt"></i>
                            <span>123 Ice Cream Street,<br>New York, NY 10001</span>
                        </li>
                        <li>
                            <i class="fas fa-phone"></i>
                            <span>+1 (012) 345 6789</span>
                        </li>
                        <li>
                            <i class="fas fa-envelope"></i>
                            <span>info@icream.com</span>
                        </li>
                        <li>
                            <i class="fas fa-clock"></i>
                            <span>Mon - Sat: 8AM - 9PM<br>Sunday: 10AM - 6PM</span>
                        </li>
                    </ul>
                </div>

            </div>

            <!-- Footer Bottom -->
            <div class="footer-bottom">
                <div class="footer-bottom-wrapper">
                    <p>&copy; 2026 <strong>iCREAM</strong>. All Rights Reserved.</p>
                    <div class="footer-bottom-links">
                        <a asp-action="Privacy" asp-controller="Home">Privacy Policy</a>
                        <span>|</span>
                        <a asp-action="Faq" asp-controller="Home">FAQ</a>
                    </div>
                </div>
            </div>

        </div>
    </footer>
    <!-- ============================================
   FOOTER END
============================================ -->
    <!-- Back to Top Button -->
    <a href="#" class="back-to-top" id="backToTop">
        <i class="fas fa-arrow-up"></i>
    </a>
               
    <!-- Footer End -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
