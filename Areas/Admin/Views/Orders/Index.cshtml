@using Ice_Cream_Parlour_Eproject.Models
@model OrderListViewModel

@{
    ViewData["Title"] = "Orders";
}

<div class="page-header">
    <div>
        <h2>Order Management</h2>
        <p>Track and manage all customer orders</p>
    </div>
    <a asp-action="Create" class="btn btn-primary-custom"><i class="fas fa-plus me-2"></i>New Order</a>
</div>

<div class="table-card">
    <div class="table-header">
        <form method="get" class="d-flex gap-2 flex-wrap">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" name="search" value="@Model.SearchTerm" placeholder="Search orders..." />
            </div>
            <select name="status" class="form-select form-select-sm" style="width:auto" onchange="this.form.submit()">
                <option value="">All Status</option>
                @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
        </form>
    </div>
    <div class="table-responsive">
        <table class="table table-premium mb-0">
            <thead>
                <tr><th>Order #</th><th>Customer</th><th>Date</th><th>Total</th><th>Order Status</th><th>Payment</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Orders.Items)
                {
                    <tr>
                        <td data-label="Order"><strong>@o.OrderNumber</strong></td>
                        <td data-label="Customer">@o.CustomerName</td>
                        <td data-label="Date">@o.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td data-label="Total"><strong>$@o.TotalAmount.ToString("N2")</strong></td>
                        <td data-label="Status"><span class="badge-status badge-@o.OrderStatus.ToString().ToLower()">@o.OrderStatus</span></td>
                        <td data-label="Payment"><span class="badge-status badge-@o.PaymentStatus.ToString().ToLower()">@o.PaymentStatus</span></td>
                        <td data-label="Actions">
                            <a asp-action="Details" asp-route-id="@o.Id" class="btn-action view" title="Details"><i class="fas fa-eye"></i></a>
                            <a asp-action="Invoice" asp-route-id="@o.Id" class="btn-action print" title="Invoice"><i class="fas fa-file-invoice"></i></a>
                            <a asp-action="ExportPdf" asp-route-id="@o.Id" class="btn-action view" title="PDF"><i class="fas fa-file-pdf"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Orders.TotalPages > 1)
    {
        <div class="p-3">
            <ul class="pagination pagination-custom justify-content-center mb-0">
                @for (int i = 1; i <= Model.Orders.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Orders.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchTerm" asp-route-status="@Model.StatusFilter">@i</a>
                    </li>
                }
            </ul>
        </div>
    }
</div>
