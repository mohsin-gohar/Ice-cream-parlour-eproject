@model Ice_Cream_Parlour_Eproject.Models.Category
@{
    ViewData["Title"] = "Delete Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Delete Category</h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back
        </a>
    </div>

    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <i class="fas fa-exclamation-triangle me-2"></i> Confirm Deletion
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-circle me-2"></i>
                Are you sure you want to delete this category? This action cannot be undone.
            </div>

            <div class="row mt-4">
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Id)</dt>
                        <dd class="col-sm-8">@Model.Id</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Name)</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Description)</dt>
                        <dd class="col-sm-8">@(Model.Description ?? "N/A")</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.IsActive)</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.CreatedDate)</dt>
                        <dd class="col-sm-8">@Model.CreatedDate.ToString("dd-MMM-yyyy HH:mm")</dd>
                    </dl>
                </div>
            </div>

            <form asp-action="DeleteConfirmed" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash me-2"></i>Confirm Delete
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
