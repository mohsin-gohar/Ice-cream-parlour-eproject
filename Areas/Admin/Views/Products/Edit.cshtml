@using Ice_Cream_Parlour_Eproject.Models
@using Ice_Cream_Parlour_Eproject.Models.Entities
@model ProductViewModel
@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<div class="page-header">
    <div><h2>Edit Product</h2></div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="form-card">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control form-control-custom" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="CategoryId" class="form-label"></label>
                        <select asp-for="CategoryId" class="form-select form-control-custom">
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control form-control-custom" rows="3"></textarea>
                    </div>
                    <div class="col-md-3 mb-3"><label asp-for="Price" class="form-label"></label><input asp-for="Price" class="form-control form-control-custom" type="number" step="0.01" /></div>
                    <div class="col-md-3 mb-3"><label asp-for="DiscountPercent" class="form-label"></label><input asp-for="DiscountPercent" class="form-control form-control-custom" type="number" step="0.01" /></div>
                    <div class="col-md-3 mb-3"><label asp-for="StockQuantity" class="form-label"></label><input asp-for="StockQuantity" class="form-control form-control-custom" type="number" /></div>
                    <div class="col-md-3 mb-3"><label asp-for="LowStockThreshold" class="form-label"></label><input asp-for="LowStockThreshold" class="form-control form-control-custom" type="number" /></div>
                    <div class="col-md-4 mb-3"><label asp-for="Barcode" class="form-label"></label><input asp-for="Barcode" class="form-control form-control-custom" /></div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        @* ✅ FIX: Explicitly use Entities.ProductStatus to avoid ambiguity *@
                        <select asp-for="Status" class="form-select form-control-custom" asp-items="Html.GetEnumSelectList<ProductStatus>()"></select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Add Images</label>
                        <input asp-for="NewImages" type="file" accept="image/*" multiple class="form-control form-control-custom" data-image-preview="#imagePreview" />
                        <div id="imagePreview" class="image-preview-grid">
                            @foreach (var img in Model.ExistingImages)
                            {
                                <div class="image-preview-item"><img src="@img" alt="Product" /></div>
                            }
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary-custom"><i class="fas fa-save me-2"></i>Update Product</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}