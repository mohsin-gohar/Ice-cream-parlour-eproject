@model Ice_Cream_Parlour_Eproject.Models.ProductViewModel
@{
    ViewData["Title"] = "Products";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Product Management</h2>
            <p class="text-muted">Manage ice cream products, recipes and pricing</p>
        </div>
        <a asp-action="CreateProduct" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Product
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Type</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Products.Items)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImagePath))
                                    {
                                        <img src="@item.ImagePath" style="width:50px; height:50px; object-fit:cover; border-radius:8px;" />
                                    }
                                    else
                                    {
                                        <div style="width:50px; height:50px; background:#f0f0f0; border-radius:8px; display:flex; align-items:center; justify-content:center;">
                                            <i class="fas fa-ice-cream text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td><strong>@item.Name</strong></td>
                                <td><span class="badge bg-info">@item.Category</span></td>
                                <td>
                                    @if (item.IsFree)
                                    {
                                        <span class="badge bg-success">Free</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Premium</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="EditProduct" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="DeleteProduct" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this product?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>