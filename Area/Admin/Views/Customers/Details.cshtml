@model CustomerViewModel
@using Ice_Cream_Parlour.Data.Entities
@{
    ViewData["Title"] = "Customer Details";
    var orders = ViewBag.Orders as List<Order> ?? new List<Order>();
}

<div class="page-header">
    <div>
        <h2>@Model.FullName</h2>
        <p>Customer profile and order history</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary-custom"><i class="fas fa-edit me-2"></i>Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="glass-card text-center">
            @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
            {
                <img src="@Model.ProfileImagePath" class="avatar mb-3" style="width:100px;height:100px" alt="@Model.FullName" />
            }
            else
            {
                <div class="avatar-placeholder mx-auto mb-3" style="width:100px;height:100px;font-size:2rem">@Model.FullName.Substring(0,1)</div>
            }
            <h4>@Model.FullName</h4>
            <p class="text-muted mb-1"><i class="fas fa-envelope me-2"></i>@Model.Email</p>
            <p class="text-muted mb-1"><i class="fas fa-phone me-2"></i>@(Model.Phone ?? "N/A")</p>
            <p class="text-muted"><i class="fas fa-map-marker-alt me-2"></i>@(Model.Address ?? "N/A")</p>
            <span class="badge-status @(Model.IsActive ? "badge-active" : "badge-inactive") mt-2">@(Model.IsActive ? "Active" : "Inactive")</span>
            <hr />
            <div class="row text-center">
                <div class="col-6"><h5>@Model.TotalOrders</h5><small class="text-muted">Orders</small></div>
                <div class="col-6"><h5>$@Model.TotalSpent.ToString("N0")</h5><small class="text-muted">Total Spent</small></div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="table-card">
            <div class="table-header"><h5><i class="fas fa-history me-2"></i>Order History</h5></div>
            @if (orders.Any())
            {
                <div class="table-responsive">
                    <table class="table table-premium mb-0">
                        <thead><tr><th>Order #</th><th>Date</th><th>Total</th><th>Status</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var o in orders)
                            {
                                <tr>
                                    <td>@o.OrderNumber</td>
                                    <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                                    <td>$@o.TotalAmount.ToString("N2")</td>
                                    <td><span class="badge-status badge-@o.OrderStatus.ToString().ToLower()">@o.OrderStatus</span></td>
                                    <td><a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id" class="btn-action view"><i class="fas fa-eye"></i></a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state"><i class="fas fa-shopping-cart"></i><p>No orders yet</p></div>
            }
        </div>
    </div>
</div>
